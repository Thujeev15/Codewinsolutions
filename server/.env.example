# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/codeflex

# Server Port
PORT=5003

# Email Configuration (Gmail)
# To use Gmail, you need to:
# 1. Go to Google Account Settings
# 2. Enable 2-Factor Authentication
# 3. Generate an App Password (https://myaccount.google.com/apppasswords)
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-digit-app-password

# Company Contact Details
COMPANY_EMAIL=hr@codeflex.lk
COMPANY_WHATSAPP=+94761302004

# Meta WhatsApp Business API Configuration
# Setup Guide: https://developers.facebook.com/docs/whatsapp/cloud-api/get-started
# Steps to get credentials:
# 1. Create Meta Business account at business.facebook.com
# 2. Create an App in Meta Developers Console (developers.facebook.com)
# 3. Add WhatsApp product to your app
# 4. Get Phone Number ID from API Setup dashboard
# 5. Generate Permanent Access Token (System User token recommended)
# Free tier: 1,000 conversations/month
WHATSAPP_ACCESS_TOKEN=your-meta-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
